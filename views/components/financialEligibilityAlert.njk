{% from "moj/components/alert/macro.njk" import mojAlert %}
{% macro financialEligibilityAlert(state) %}
{% if state == "yes" %}
    {{ mojAlert({
      variant: "success",
      text: t("common.financialEligibility.alert.success")
    }) }}

  {% elseif state == "no" %}
    {{ mojAlert({
      variant: "warning",
      text: t("common.financialEligibility.alert.warning")
    }) }}

  {% elseif state == "unknown" %}
    {{ mojAlert({
      variant: "information",
      title: t("common.financialEligibility.alert.informationTitle"),
      showTitleAsHeading: true,
      text: t("common.financialEligibility.alert.information")
    }) }}

  {% endif %}
{% endmacro %}