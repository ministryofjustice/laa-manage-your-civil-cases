{% extends "base.njk" %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/input/macro.njk" import govukInput %}
{% from "govuk/components/password-input/macro.njk" import govukPasswordInput %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}

{% block pageContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% if error %}
        {{ govukErrorSummary({
          titleText: "There is a problem",
          errorList: [
            {
              text: error,
              href: "#username"
            },
            {
              text: error,
              href: "#password"
            }
          ]
        }) }}
      {% endif %}

      <h1 class="govuk-heading-xl">{{ t('pages.login.heading') }}</h1>

      <form action="/login" method="POST" class="govuk-form">
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">

        {{ govukInput({
          id: "username",
          name: "username",
          type: "text",
          classes: "govuk-!-width-one-third",
          label: {
            text: t('pages.login.username'),
            classes: "govuk-body"
          },
          errorMessage: {
            text: error
          } if error else undefined
        }) }}

        {{ govukPasswordInput({
          id: "password",
          name: "password",
          classes: "govuk-!-width-one-third",
          label: {
            text: t('pages.login.password'),
            classes: "govuk-body"
          },
          errorMessage: {
            text: error
          } if error else undefined
        }) }}

        {{ govukButton({
          text: t('pages.login.signInButton'),
          type: "submit",
          classes: "govuk-!-font-weight-bold"
        }) }}
      </form>
    </div>
  </div>
{% endblock %}