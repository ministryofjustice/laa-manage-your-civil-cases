{% from "components/summaryCardComponent.njk" import summaryCardComponent %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tabs/macro.njk" import govukTabs %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% set editAssessmentButtonHtml %}
  {{
    govukButton({
      text: "Edit assessment",
      classes: "govuk-button--secondary",
      href: "/cases/" + caseReference + "/financial-eligibility/change"
    })
  }}
{% endset %}

{% set detailsHtml %}
  {% if financialEligibility.isUnder17 %}
   {% set under17Text = "Yes" %}
  {% else %}
   {% set under17Text = "No" %}
  {% endif %}

  {% if financialEligibility.hasPartner %}
    {% set partnerText = "Yes" %}
  {% else %}
    {% set partnerText = "No" %}
  {% endif %}

  {% if financialEligibility.isOver60 %}
    {% set over60Text = "Yes" %}
  {% else %}
    {% set over60Text = "No" %}
  {% endif %}

  {% set rows = [
    [{ text: "Are you aged 17 or under?" }, { text: under17Text }]
  ] %}
  {% if not financialEligibility.isUnder17 %}
    {% set rows = rows.concat([
      [{ text: "Do you have a partner?" }, { text: partnerText }],
      [{ text: "Are you aged 60 or over?" }, { text: over60Text }]
    ]) %}
  {% endif %}

  {{ govukTable({
    caption: "About you",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: rows
  }) }}

  {{ govukTable({
    caption: "Benefits",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "Universal Credit"
        },
        {
          text: "Yes"
        }
      ],
      [
        {
          text: "Income Support"
        },
        {
          text: "No"
        }
      ],
      [
        {
          text: "Income-based Job Seekers Allowance"
        },
        {
          text: "No"
        }
      ],
      [
        {
          text: "Guarantee State Pension Credit"
        },
        {
          text: "No"
        }
      ],
      [
        {
          text: "Income-related Employment and Support Allowance"
        },
        {
          text: "No"
        }
      ]
    ]
  }) }}

  <div> {{ editAssessmentButtonHtml | safe }}</div>
{% endset -%}

{% set financesHtml %}
  {{ govukTable({
    caption: "Finances",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "Do you have any??"
        },
        {
          text: "No"
        }
      ]
    ]
  }) }}

  <div> {{ editAssessmentButtonHtml | safe }}</div>
{% endset -%}

{% set incomeHtml %}
  {{ govukTable({
    caption: "Income",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "Do you have any??"
        },
        {
          text: "No"
        }
      ]
    ]
  }) }}

  <div> {{ editAssessmentButtonHtml | safe }}</div>
{% endset -%}

{% set expensesHtml %}
  {{ govukTable({
    caption: "Expenses",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "Do you have any??"
        },
        {
          text: "No"
        }
      ]
    ]
  }) }}

  <div> {{ editAssessmentButtonHtml | safe }}</div>
{% endset -%}


<p> NOTE: This will show the existing financial eligibility for this case from `cla_backend`</p>

{{ govukTabs({
    id: "about-you-tabs",
    items: [
      {
          label: "Details",
          id: "details",
          panel: {
              html: detailsHtml
          }
      },
      {
          label: "Finances",
          id: "finances",
          panel: {
              html: financesHtml
          }
      },
      {
          label: "Income",
          id: "income",
          panel: {
              html: incomeHtml
          }
      },
      {
          label: "Expenses",
          id: "expenses",
          panel: {
              html: expensesHtml
          }
      }
    ]
}) }}