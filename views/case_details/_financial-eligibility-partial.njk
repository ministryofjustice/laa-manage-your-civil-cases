          text: t("common.financialEligibility.expenses.partnerLegalAidCost")
        },
        {
          text: "£" ~ partnerDeductions.criminalContributions.amount ~ " " ~ t("common.intervalPeriod." ~ partnerDeductions.criminalContributions.time)
        }
      ]
    ]
