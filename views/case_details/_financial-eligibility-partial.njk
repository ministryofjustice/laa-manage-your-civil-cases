{% from "components/summaryCardComponent.njk" import summaryCardComponent %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tabs/macro.njk" import govukTabs %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% set editAssessmentButtonHtml %}
{{
    govukButton({
      text: "Edit assessment",
      classes: "govuk-button--secondary",
      href: "/cases/" + caseReference + "/financial-eligibility/change"
    })
  }}
{% endset %}

{% set detailsHtml %}

{% set under17Text = "Yes" if financialEligibility.isUnder17 else 
  "No" %}
{% set partnerText = "Yes" if financialEligibility.hasPartner else 
  "No" %}
{% set over60Text = "Yes" if financialEligibility.isOver60 else "No"%}
{% set universalCredit = "Yes" if financialEligibility.specificBenefits.universalCredit else "No"%}
{% set pensionCredit = "Yes" if financialEligibility.specificBenefits.pensionCredit else "No"%}
{% set jobSeekers = "Yes" if financialEligibility.specificBenefits.jobSeekers else "No"%}
{% set employmentSupport = "Yes" if financialEligibility.specificBenefits.employmentSupport else "No"%}
{% set incomeSupport = "Yes" if financialEligibility.specificBenefits.incomeSupport else "No"%}

{% set rows = [
  [
    {
      text: t("common.financialEligibility.details.age17OrUnder")
    }, {
      text: under17Text
    }
  ]
] %}
{% if not financialEligibility.isUnder17 %}
  {% set rows = rows.concat([
    [
      {
        text: t("common.financialEligibility.details.hasPartner")
      }, {
        text: partnerText
      }
    ],
    [
      {
        text: t("common.financialEligibility.details.age60OrOver")
      }, {
        text: over60Text
      }
    ]
  ]) %}
{% endif %}

{{ govukTable({
    caption: "About you",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: rows
  }) }}

{{ govukTable({
    caption: "Benefits",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: t("common.financialEligibility.details.universalCredit")
        },
        {
          text: universalCredit
        }
      ],
      [
        {
          text: t("common.financialEligibility.details.incomeSupport")
        },
        {
          text: incomeSupport
        }
      ],
      [
        {
          text: t("common.financialEligibility.details.incomeBasedJSA")
        },
        {
          text: jobSeekers
        }
      ],
      [
        {
          text: t("common.financialEligibility.details.pensionCredit")
        },
        {
          text: pensionCredit
        }
      ],
      [
        {
          text: t("common.financialEligibility.details.employmentSupport")
        },
        {
          text: employmentSupport
        }
      ]
    ]
  }) }}

<div>
  {{ editAssessmentButtonHtml | safe }}</div>
{% endset -%}

{% set financesHtml %}

<h2 class="govuk-heading-m">Properties</h2>
{% if financialEligibility.propertySet and financialEligibility.propertySet.length %}

  {% for property in financialEligibility.propertySet %}

    <h3 class="govuk-heading-s">
      {% if loop.index == 1 %}
        1st property
      {% elseif loop.index == 2 %}
        2nd property
      {% elseif loop.index == 3 %}
        3rd property
      {% else %}
        {{ loop.index }}th property
      {% endif %}
    </h3>

    {{ govukTable({
      firstCellIsHeader: true,
      rows: [
        [
          { text: t("common.financialEligibility.finances.propertyValue") },
          { text: "£" ~ property.value }
        ],
        [
          { text: t("common.financialEligibility.finances.mortgageLeft") },
          { text: "£" ~ property.mortgageLeft }
        ],
        [
          { text: t("common.financialEligibility.finances.mainProperty") },
          { text: "Yes" if property.main else "No" }
        ],
        [
          { text: t("common.financialEligibility.finances.propertyShare") },
          { text: property.share + "%" }
        ]
      ]
    }) }}

  {% endfor %}

{% else %}

  <p class="govuk-body">No property data</p>

{% endif %}

<h2 class="govuk-heading-m">Your savings</h2>

{% set savings = financialEligibility.clientData.savings %}

{{ govukTable({
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: t("common.financialEligibility.finances.savingsBalance")
        },
        {
          text: "£" ~ savings.bankBalance
        }
      ],
      [
        {
          text: t("common.financialEligibility.finances.investmentBalance")
        },
        {
          text: "£" ~ savings.investmentBalance
        }
      ],
      [
        {
          text: t("common.financialEligibility.finances.assetBalance")
        },
        {
          text: "£" ~ savings.assetBalance
        }
      ],
      [
        {
          text: t("common.financialEligibility.finances.creditBalance")
        },
        {
          text: "£" ~ savings.creditBalance
        }
      ]
    ]
  }) }}

{% if financialEligibility.hasPartner %}
  <h2 class="govuk-heading-m">Your partners savings</h2>

  {% set partnerSavings = financialEligibility.partnerData.partnerSavings %}

  {{ govukTable({
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: t("common.financialEligibility.finances.partnerSavingsBalance")
        },
        {
          text: "£" ~ partnerSavings.bankBalance
        }
      ],
      [
        {
          text: t("common.financialEligibility.finances.partnerInvestmentBalance")
        },
        {
          text: "£" ~ partnerSavings.investmentBalance
        }
      ],
      [
        {
          text: t("common.financialEligibility.finances.partnerAssetBalance")
        },
        {
          text: "£" ~ partnerSavings.assetBalance
        }
      ],
      [
        {
          text: t("common.financialEligibility.finances.partnerCreditBalance")
        },
        {
          text: "£" ~ partnerSavings.creditBalance
        }
      ]
    ]
  }) }}
{% endif %}

  <h2 class="govuk-heading-m">Disregards</h2>

  <table class="govuk-table">
    <tbody class="govuk-table__body">
      {% for disregard in financialEligibility.disregards %}
        <tr class="govuk-table__row">
          <td class="govuk-table__cell">
            {{ disregard }}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

{{ editAssessmentButtonHtml | safe }}
{% endset -%}

{% set income = financialEligibility.clientData.income %}
{% set deductions = financialEligibility.clientData.deductions %}

{% set incomeHtml %}
{{ govukTable({
    caption: "Your income",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: t("common.financialEligibility.income.selfEmployed")
        },
        {
          text: "Yes" if income.selfEmployed else "No"
        }
      ],
      [
        {
          text: t("common.financialEligibility.income.earnings")
        },
        {
          text: "£" ~ income.earnings.amount ~ " " ~ t("common.intervalPeriod." ~ income.earnings.time)
        }
      ],
      [
        {
          text: t("common.financialEligibility.income.tax")
        },
        {
          text: "£" ~ deductions.incomeTax.amount ~ " " ~ t("common.intervalPeriod." ~ deductions.incomeTax.time)
        }
