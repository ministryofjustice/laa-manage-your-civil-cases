      caption: "Your partner's expenses",
      classes: "eligibility-table",
      captionClasses: "govuk-table__caption--m",
      firstCellIsHeader: true,
      rows: [
        [
          {
            text: t("common.financialEligibility.expenses.partnerMortgageCost")
          },
          {
            text: (partnerDeductions.mortgage | formatFinancialData)
          }
        ],
        [
          {
            text: t("common.financialEligibility.expenses.partnerRentCost")
          },
          {
            text: (partnerDeductions.rent | formatFinancialData)
          }
        ],
        [
          {
            text: t("common.financialEligibility.expenses.partnerMaintenanceCost")
          },
          {
            text: (partnerDeductions.maintenance | formatFinancialData)
          }
        ],
        [
          {
            text: t("common.financialEligibility.expenses.partnerChildCareCost")
          },
          {
            text: (partnerDeductions.childcare | formatFinancialData)
          }
        ],
        [
          {
            text: t("common.financialEligibility.expenses.partnerLegalAidCost")
          },
          {
            text: (partnerDeductions.criminalContributions | formatFinancialData)
          }
        ]
      ]
    }) }}
  {% endif %}
  <div>{{ editAssessmentButtonHtml | safe }}</div>
{% endset -%}

<h2 class="govuk-heading-m">{{ t('pages.caseDetails.tabs.financialEligibility') }}</h2>
<div class="financial-eligibility-alert">
{{ financialEligibilityAlert(financialEligibility.state) }}
</div>

{{ govukTabs({
    id: "financial-eligibility-tabs",
    items: [
      {
        label: "Details",
        id: "details",
        panel: {
            html: detailsHtml
        }
      },
      {
        label: "Finances",
        id: "finances",
        panel: {
            html: financesHtml
        }
      },
      {
        label: "Income",
        id: "income",
        panel: {
            html: incomeHtml
        }
      },
      {
        label: "Expenses",
        id: "expenses",
        panel: {
             html: expensesHtml
        }
      }
    ]
}) }}