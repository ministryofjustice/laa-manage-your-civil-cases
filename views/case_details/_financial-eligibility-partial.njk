  {{ editAssessmentButtonHtml | safe }}
{% endset -%}

{{ govukTabs({
    id: "about-you-tabs",
    items: [
      {
          label: "Details",
          id: "details",
          panel: {
              html: detailsHtml
          }
      },
      {
          label: "Finances",
          id: "finances",
          panel: {
              html: financesHtml
          }
      },
      {
          label: "Income",
          id: "income",
          panel: {
