{% from "components/summaryCardComponent.njk" import summaryCardComponent %}
{% from "govuk/components/warning-text/macro.njk" import govukWarningText %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/tabs/macro.njk" import govukTabs %}
{% from "govuk/components/table/macro.njk" import govukTable %}

{% set editAssessmentButtonHtml %}
{{
    govukButton({
      text: "Edit assessment",
      classes: "govuk-button--secondary",
      href: "/cases/" + caseReference + "/financial-eligibility/change"
    })
  }}
{% endset %}

{% set detailsHtml %}

{% set under17Text = "Yes" if financialEligibility.isUnder17 else 
  "No" %}
{% set partnerText = "Yes" if financialEligibility.hasPartner else 
  "No" %}
{% set over60Text = "Yes" if financialEligibility.isOver60 else "No"%}
{% set universalCredit = "Yes" if financialEligibility.specificBenefits.universalCredit else "No"%}
{% set pensionCredit = "Yes" if financialEligibility.specificBenefits.pensionCredit else "No"%}
{% set jobSeekers = "Yes" if financialEligibility.specificBenefits.jobSeekers else "No"%}
{% set employmentSupport = "Yes" if financialEligibility.specificBenefits.employmentSupport else "No"%}
{% set incomeSupport = "Yes" if financialEligibility.specificBenefits.incomeSupport else "No"%}

{% set rows = [
  [
    {
      text: "Are you aged 17 or under?"
    }, {
      text: under17Text
    }
  ]
] %}
{% if not financialEligibility.isUnder17 %}
  {% set rows = rows.concat([
    [
      {
        text: "Do you have a partner?"
      }, {
        text: partnerText
      }
    ],
    [
      {
        text: "Are you aged 60 or over?"
      }, {
        text: over60Text
      }
    ]
  ]) %}
{% endif %}

{{ govukTable({
    caption: "About you",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: rows
  }) }}

{{ govukTable({
    caption: "Benefits",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "Universal Credit"
        },
        {
          text: universalCredit
        }
      ],
      [
        {
          text: "Income Support"
        },
        {
          text: incomeSupport
        }
      ],
      [
        {
          text: "Income-based Job Seekers Allowance"
        },
        {
          text: jobSeekers
        }
      ],
      [
        {
          text: "Guarantee State Pension Credit"
        },
        {
          text: pensionCredit
        }
      ],
      [
        {
          text: "Income-related Employment and Support Allowance"
        },
        {
          text: employmentSupport
        }
      ]
    ]
  }) }}

<div>
  {{ editAssessmentButtonHtml | safe }}</div>
{% endset -%}

{% set financesHtml %}

<h2 class="govuk-heading-m">Properties</h2>
{% if financialEligibility.propertySet and financialEligibility.propertySet.length %}

  {% for property in financialEligibility.propertySet %}

    <h3 class="govuk-heading-s">
      {% if loop.index == 1 %}
        1st property
      {% elseif loop.index == 2 %}
        2nd property
      {% elseif loop.index == 3 %}
        3rd property
      {% else %}
        {{ loop.index }}th property
      {% endif %}
    </h3>

    {{ govukTable({
      firstCellIsHeader: true,
      rows: [
        [
          { text: "What is the current market value of the property?" },
          { text: "£" ~property.value }
        ],
        [
          { text: "How much is left to pay on the mortgage?" },
          { text: "£" ~ property.mortgageLeft }
        ],
        [
          { text: "Is this your main property?" },
          { text: "Yes" if property.main else "No" }
        ],
        [
          { text: "What percentage of the property do you and/or your partner own?" },
          { text: property.share + "%" }
        ]
      ]
    }) }}

  {% endfor %}

{% else %}

  <p class="govuk-body">No property data</p>

{% endif %}

<h2 class="govuk-heading-m">Your savings</h2>

{% set savings = financialEligibility.clientData.savings %}

{{ govukTable({
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "How much was in your bank account/building society before your last payment went in?"
        },
        {
          text: "£" ~ savings.bankBalance
        }
      ],
      [
        {
          text: "Do you have any investments, shares or ISAs?"
        },
        {
          text: "£" ~ savings.investmentBalance
        }
      ],
      [
        {
          text: "Do you have any valuable items worth over £500 each?"
        },
        {
          text: "£" ~ savings.assetBalance
        }
      ],
      [
        {
          text: "Do you have any money owed to you?"
        },
        {
          text: "£" ~ savings.creditBalance
        }
      ]
    ]
  }) }}

{% if financialEligibility.hasPartner %}
  <h2 class="govuk-heading-m">Your partners savings</h2>

  {% set partnerSavings = financialEligibility.partnerData.partnerSavings %}

  {{ govukTable({
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "How much was in your partners bank account/building society before their last payment went in?"
        },
        {
          text: "£" ~ partnerSavings.bankBalance
        }
      ],
      [
        {
          text: "Does your partner have any investments, shares or ISAs?"
        },
        {
          text: "£" ~ partnerSavings.investmentBalance
        }
      ],
      [
        {
          text: "Does your partner have any valuable items worth over £500 each?"
        },
        {
          text: "£" ~ partnerSavings.assetBalance
        }
      ],
      [
        {
          text: "Does your partner have any money owed to them?"
        },
        {
          text: "£" ~ partnerSavings.creditBalance
        }
      ]
    ]
  }) }}
{% endif %}

  <h2 class="govuk-heading-m">Disregards</h2>

  <table class="govuk-table">
    <tbody class="govuk-table__body">
      {% for disregard in financialEligibility.disregards %}
        <tr class="govuk-table__row">
          <td class="govuk-table__cell">
            {{ disregard }}
          </td>
        </tr>
      {% endfor %}
    </tbody>
  </table>

{{ editAssessmentButtonHtml | safe }}
{% endset -%}

{% set income = financialEligibility.clientData.income %}
{% set deductions = financialEligibility.clientData.deductions %}

{% set incomeHtml %}
{{ govukTable({
    caption: "Your income",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "Are you self employed?"
        },
        {
          text: "Yes" if income.selfEmployed else "No"
        }
      ],
      [
        {
          text: "What did you earn before tax? (Check your most recent payslips)"
        },
        {
          text: "£" ~ income.earnings.amount ~ " " ~ t("common.intervalPeriod." ~ income.earnings.time)
        }
      ],
      [
        {
          text: "How much tax do you pay?"
        },
        {
          text: "£" ~ deductions.incomeTax.amount ~ " " ~ t("common.intervalPeriod." ~ deductions.incomeTax.time)
        }
      ],
      [
        {
          text: "How much National Insurance do you pay?"
        },
        {
          text: "£" ~ deductions.nationalInsurance.amount ~ " " ~ t("common.intervalPeriod." ~ deductions.nationalInsurance.time)
        }
      ],
      [
        {
          text: "Self employed drawings (before tax)"
        },
        {
          text: "£" ~ income.selfEmploymentDrawings.amount ~ " " ~ t("common.intervalPeriod." ~ income.selfEmploymentDrawings.time)
        }
      ],
      [
        {
          text: "Benefits"
        },
        {
          text: "£" ~ income.benefits.amount ~ " " ~ t("common.intervalPeriod." ~ income.benefits.time)
        }
      ],
      [
        {
          text: "Tax credits"
        },
        {
          text: "£" ~ income.taxCredits.amount ~ " " ~ t("common.intervalPeriod." ~ income.taxCredits.time)
        }
      ],
        [
        {
          text: "Child benefit (for household)"
        },
        {
          text: "£" ~ income.childBenefit.amount ~ " " ~ t("common.intervalPeriod." ~ income.childBenefit.time)
        }
      ],
         [
        {
          text: "Maintenance received"
        },
        {
          text: "£" ~ income.maintenanceReceived.amount ~ " " ~ t("common.intervalPeriod." ~ income.maintenanceReceived.time)
        }
      ],
         [
        {
          text: "Pension income"
        },
        {
          text: "£" ~ income.pension.amount ~ " " ~ t("common.intervalPeriod." ~ income.pension.time)
        }
      ],
      [
        {
          text: "Other income"
        },
        {
          text: "£" ~ income.otherIncome.amount ~ " " ~ t("common.intervalPeriod." ~ income.otherIncome.time)
        }
      ]
    ]
  }) }}

{% set partnerIncome = financialEligibility.partnerData.partnerIncome %}
{% set partnerDeductions = financialEligibility.partnerData.partnerDeductions %}

{% if financialEligibility.hasPartner %}
  {{ govukTable({
    caption: "Partner's income",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "Are you self employed?"
        },
        {
          text: "Yes" if partnerIncome.selfEmployed else "No"
        }
      ],
      [
        {
          text: "What did you earn before tax? (Check your most recent payslips)"
        },
        {
          text: "£" ~ partnerIncome.earnings.amount ~ " " ~ t("common.intervalPeriod." ~ partnerIncome.earnings.time)
        }
      ],
      [
        {
          text: "How much tax do you pay?"
        },
        {
          text: "£" ~ partnerDeductions.incomeTax.amount ~ " " ~ t("common.intervalPeriod." ~ partnerDeductions.incomeTax.time)
        }
      ],
      [
        {
          text: "How much National Insurance do you pay?"
        },
        {
          text: "£" ~ partnerDeductions.nationalInsurance.amount ~ " " ~ t("common.intervalPeriod." ~ partnerDeductions.nationalInsurance.time)
        }
      ],
      [
        {
          text: "Self employed drawings (before tax)"
        },
        {
          text: "£" ~ partnerIncome.selfEmploymentDrawings.amount ~ " " ~ t("common.intervalPeriod." ~ partnerIncome.selfEmploymentDrawings.time)
        }
      ],
      [
        {
          text: "Benefits"
        },
        {
          text: "£" ~ partnerIncome.benefits.amount ~ " " ~ t("common.intervalPeriod." ~ partnerIncome.benefits.time)
        }
      ],
      [
        {
          text: "Tax credits"
        },
        {
          text: "£" ~ partnerIncome.taxCredits.amount ~ " " ~ t("common.intervalPeriod." ~ partnerIncome.taxCredits.time)
        }
      ],
        [
        {
          text: "Child benefit (for household)"
        },
        {
          text: "£" ~ partnerIncome.childBenefit.amount ~ " " ~ t("common.intervalPeriod." ~ partnerIncome.childBenefit.time)
        }
      ],
         [
        {
          text: "Maintenance received"
        },
        {
          text: "£" ~ partnerIncome.maintenanceReceived.amount ~ " " ~ t("common.intervalPeriod." ~ partnerIncome.maintenanceReceived.time)
        }
      ],
         [
        {
          text: "Pension income"
        },
        {
          text: "£" ~ partnerIncome.pension.amount ~ " " ~ t("common.intervalPeriod." ~ partnerIncome.pension.time)
        }
      ],
      [
        {
          text: "Other income"
        },
        {
          text: "£" ~ partnerIncome.otherIncome.amount ~ " " ~ t("common.intervalPeriod." ~ partnerIncome.otherIncome.time)
        }
      ]
    ]
  }) }}

{% endif %}

{{ govukTable({
    caption: "Dependants",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "Do you have any dependants aged 16 and over?"
        },
        {
          text: financialEligibility.depedantsOld
        }
      ],
      [
        {
          text: "Do you have any dependants aged 15 and under?"
        },
        {
          text: financialEligibility.depedantsYoung
        }
      ]
    ]
  }) }}

{{ editAssessmentButtonHtml | safe }}
{% endset -%}

{% set expensesHtml %}
{{ govukTable({
    caption: "Your expenses",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "How much do you pay for your mortgage?"
        },
        {
          text: "£" ~ deductions.mortgage.amount ~ " " ~ t("common.intervalPeriod." ~ deductions.mortgage.time)
        }
      ],
       [
        {
          text: "How much do you pay for rent? The amount entered should not include any housing benefit or payment for bills"
        },
        {
          text: "£" ~deductions.rent.amount ~ " " ~ t("common.intervalPeriod." ~ deductions.rent.time)
        }
      ],
       [
        {
          text: "How much maintenance have you paid during the last calendar month?"
        },
        {
          text: "£" ~deductions.maintenance.amount ~ " " ~ t("common.intervalPeriod." ~ deductions.maintenance.time)
        }
      ],
       [
        {
          text: "Do you have any childcare costs because of work or study? If so, how much?"
        },
        {
          text: "£" ~ deductions.childcare.amount ~ " " ~ t("common.intervalPeriod." ~ deductions.childcare.time)
        }
      ],
       [
        {
          text: "Are you currently paying towards legal aid for criminal defence? If so, how much have you paid in the last calendar month?"
        },
        {
          text: "£" ~ deductions.criminalContributions.amount ~ " " ~ t("common.intervalPeriod." ~ deductions.criminalContributions.time)
        }
      ]
    ]
  }) }}

{% if financialEligibility.hasPartner %}
  {{ govukTable({
    caption: "Your partner's expenses",
    captionClasses: "govuk-table__caption--m",
    firstCellIsHeader: true,
    rows: [
      [
        {
          text: "How much does your partner pay for their mortgage?"
        },
        {
          text: "£" ~ partnerDeductions.mortgage.amount ~ " " ~ t("common.intervalPeriod." ~ partnerDeductions.mortgage.time)
        }
      ],
       [
        {
          text: "How much does your partner pay for their rent? The amount entered should not include any housing benefit or payment for bills"
        },
        {
          text: "£" ~ partnerDeductions.rent.amount ~ " " ~ t("common.intervalPeriod." ~ partnerDeductions.rent.time)
        }
      ],
       [
        {
          text: "How much maintenance has your partner paid during the last calendar month?"
        },
        {
          text: "£" ~ partnerDeductions.maintenance.amount ~ " " ~ t("common.intervalPeriod." ~ partnerDeductions.maintenance.time)
        }
      ],
       [
        {
          text: "Does your partner have any childcare costs because of work or study? If so, how much?"
        },
        {
          text: "£" ~ partnerDeductions.childcare.amount ~ " " ~ t("common.intervalPeriod." ~ partnerDeductions.childcare.time)
        }
      ],
       [
        {
          text: "Is your partner currently paying towards legal aid for criminal defence? If so, how much has your partner paid in the last calendar month?"
        },
        {
          text: "£" ~ partnerDeductions.criminalContributions.amount ~ " " ~ t("common.intervalPeriod." ~ partnerDeductions.criminalContributions.time)
        }
      ]
    ]
  }) }}

{% endif %}
  {{ editAssessmentButtonHtml | safe }}
{% endset -%}

{{ govukTabs({
    id: "about-you-tabs",
    items: [
      {
          label: "Details",
          id: "details",
          panel: {
              html: detailsHtml
          }
      },
      {
          label: "Finances",
          id: "finances",
          panel: {
              html: financesHtml
          }
      },
      {
          label: "Income",
          id: "income",
          panel: {
              html: incomeHtml
          }
      },
      {
          label: "Expenses",
          id: "expenses",
          panel: {
              html: expensesHtml
          }
      }
    ]
}) }}