{% extends "case_details/_base-case-change.njk" %}
{% from "govuk/components/radios/macro.njk" import govukRadios %}
{% from "govuk/components/button/macro.njk" import govukButton %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "components/errorSummaryComponent.njk" import errorSummary %}
{% from "components/alertBannerComponent.njk" import alertBannerComponent %}

{% block pageTitle %}
  {% if errorState.hasErrors %}{{ t('common.error') }}: {% endif %}{{ t('pages.caseDetails.splitCase.pageTitle', { caseReference: caseReference, serviceName: config.SERVICE_NAME }) }}
{% endblock %}

{% block backLink %}
  {# No back link for this page #}
{% endblock %}

{% block errorSummaryOrAlert %}
  {% if errorState.hasErrors %}
    {{ errorSummary(errorState.errors, t('common.errorSummaryTitle')) }}
  {% else %}
    {{ alertBannerComponent(client) }}
  {% endif %}
{% endblock %}

{% block formContent %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">

      <form method="POST" action="/cases/{{ caseReference }}/split-this-case">

        <!-- CSRF Protection -->
        <input type="hidden" name="_csrf" value="{{ csrfToken }}"/>

        <h2 class="govuk-heading-m">{{ t('pages.caseDetails.splitCase.h2') }}</h2>

        <p class="govuk-body">{{ t('pages.caseDetails.splitCase.infoText') }}
          <a class="govuk-link" href="https://assets.publishing.service.gov.uk/media/679a1a75fe19800263dc7b86/2_2025_Civil_Legal_Advice_Contract_Annex_1_Specification.pdf#page=35" target="_blank" rel="noopener noreferrer">
            {{ t('pages.caseDetails.splitCase.linkText') }}</a>
          {{ t('pages.caseDetails.splitCase.infoTextEnd') }}
        </p>

        {{ govukRadios({
          name: "internal",
          errorMessage: errorState.fieldErrors.internal,
          fieldset: {
            legend: {
              text: t('pages.caseDetails.splitCase.radioLegend'),
              isPageHeading: false,
              classes: "govuk-fieldset__legend--s"
            }
          },
          items: [
            {
              value: "true",
              text: provider.name,
              checked: splitCaseCache.internal == "true"
            },
            {
              value: "false",
              text: t('pages.caseDetails.splitCase.operatorReassignment'),
              checked: splitCaseCache.internal == "false"
            }
          ]
        }) }}

        <div class="govuk-button-group">
          {{ govukButton({
            text: t('common.continue')
          }) }}

          {% if splitCaseCache and splitCaseCache.fromChange %}
            <a class="govuk-link" href="/cases/{{ caseReference }}/check-split-case-answers">{{ t('common.cancel') }}</a>
          {% else %}
            <a class="govuk-link" href="/cases/{{ caseReference }}/client-details">{{ t('common.cancel') }}</a>
          {% endif %}

        </div>

      </form>

    </div>
  </div>
{% endblock %}