{% extends "base.njk" %}
{% from "govuk/components/error-summary/macro.njk" import govukErrorSummary %}
{% from "components/caseDetailsHeaderComponent.njk" import caseDetailsHeaderComponent %}

{% block content %}
  <div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
      {% set errorList = [] %}

      {% for error in fieldValidationErrors %}
        {% set errorList = errorList.concat([{ text: error.message, href: "#" + error.blockCode }]) %}
      {% endfor %}

      {% for error in domainValidationErrors %}
        {% set errorList = errorList.concat([{ text: error.message }]) %}
      {% endfor %}

      {% if errorList | length %}
        {{ govukErrorSummary({ titleText: "There is a problem", errorList: errorList }) }}
      {% endif %}

      {{ caseDetailsHeaderComponent(client, hideStatusButton = true) }}

      <form method="post" novalidate>
        <input type="hidden" name="_csrf" value="{{ csrfToken }}">
        {% for block in blocks %}
          {{ block | safe }}
        {% endfor %}
      </form>
    </div>
  </div>
{% endblock %}